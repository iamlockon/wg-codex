project_id                    = "my-gcp-project"
github_repository             = "my-org/my-repo"
workload_identity_pool_id     = "github-actions"
workload_identity_provider_id = "github-oidc"
terraform_service_account_id  = "gha-terraform"
enable_required_apis          = true

# Must already exist in the project before running this stack.

# Optional: override default roles for the Terraform SA.
# terraform_service_account_roles = [
#   "roles/editor",
#   "roles/resourcemanager.projectIamAdmin",
# ]

# Required: app-login OIDC values for entry-vm-cicd.
app_google_oidc_client_id     = "replace_me.apps.googleusercontent.com"
app_google_oidc_client_secret = "replace_me"
app_google_oidc_redirect_uri  = "http://127.0.0.1:1420"

# Optional: override destination GitHub secret names.
# github_secret_name_google_oidc_client_id     = "GOOGLE_OIDC_CLIENT_ID"
# github_secret_name_google_oidc_client_secret = "GOOGLE_OIDC_CLIENT_SECRET"
# github_secret_name_google_oidc_redirect_uri  = "GOOGLE_OIDC_REDIRECT_URI"
