# Reference-based startup rollout notes:
# - upload the entry binary to GCS and set Terraform rollout_artifact_ref / rollout_artifact_sha256 instead of copying a local artifact onto the VM.
# - publish this env file to Secret Manager or GCS and set rollout_env_ref so the startup script can materialize it at boot.
# - publish core mTLS materials to Secret Manager and set rollout_core_ca_secret_ref, rollout_core_client_cert_secret_ref, and rollout_core_client_key_secret_ref so the VM startup script materializes them under /etc/core-tls/.

APP_ENV=production
ENTRY_BIND_ADDR=0.0.0.0:8080
DATABASE_URL=postgres://vpn_user:replace_me@postgres:5432/vpn
# Optional file-backed variant:
# DATABASE_URL_FILE=/var/run/secrets/entry/database_url
CORE_GRPC_URL=https://core.internal.example.net:50051
CORE_GRPC_TLS_DOMAIN=core.internal.example.net
CORE_GRPC_TLS_CA_CERT_PATH=/etc/core-tls/ca.pem
CORE_GRPC_TLS_CLIENT_CERT_PATH=/etc/core-tls/client.crt
CORE_GRPC_TLS_CLIENT_KEY_PATH=/etc/core-tls/client.key
# Optional catalog-backed discovery source:
# APP_NODE_CATALOG_GCS_BUCKET=replace_me
# APP_NODE_CATALOG_GCS_OBJECT=nodes/catalog.json

APP_REQUIRE_CORE_TLS=true
APP_REQUIRE_OAUTH_NONCE=true
APP_REQUIRE_OAUTH_PKCE=true
APP_ALLOW_LEGACY_CUSTOMER_HEADER=false
APP_LOG_REDACTION_MODE=strict
APP_NODE_FRESHNESS_SECS=60
APP_CORE_NODE_GRPC_PORT=50051
APP_TERMINATED_SESSION_RETENTION_DAYS=7
APP_AUDIT_RETENTION_DAYS=30
APP_MAX_TERMINATED_SESSION_RETENTION_DAYS=30
APP_MAX_AUDIT_RETENTION_DAYS=90

APP_JWT_SIGNING_KEYS=v1:replace_me_long_random_secret
APP_JWT_ACTIVE_KID=v1
ADMIN_API_TOKEN=replace_me
# Optional file-backed variants for Secret Manager/volume mounts. In the startup rollout model, these files are populated from rollout_env_ref or Secret Manager refs during boot:
# APP_JWT_SIGNING_KEYS_FILE=/var/run/secrets/entry/jwt_signing_keys
# ADMIN_API_TOKEN_FILE=/var/run/secrets/entry/admin_api_token

GOOGLE_OIDC_CLIENT_ID=replace_me.apps.googleusercontent.com
GOOGLE_OIDC_CLIENT_SECRET=replace_me
GOOGLE_OIDC_REDIRECT_URI=http://127.0.0.1:53682/oauth/callback
# Optional file-backed variants for startup-fetched secrets:
# GOOGLE_OIDC_CLIENT_ID_FILE=/var/run/secrets/entry/google_client_id
# GOOGLE_OIDC_CLIENT_SECRET_FILE=/var/run/secrets/entry/google_client_secret
# GOOGLE_OIDC_REDIRECT_URI_FILE=/var/run/secrets/entry/google_redirect_uri
