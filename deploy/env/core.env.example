# Reference-based startup rollout notes:
# - upload the core binary to GCS and set Terraform rollout_artifact_ref / rollout_artifact_sha256 instead of copying a local artifact onto the VM.
# - publish this env file to Secret Manager or GCS and set rollout_env_ref so the startup script can materialize it at boot.
# - publish WireGuard and TLS key material to Secret Manager and set rollout_private_key_secret_ref, rollout_tls_cert_secret_ref, rollout_tls_key_secret_ref, and rollout_tls_ca_secret_ref.

APP_ENV=production
CORE_BIND_ADDR=0.0.0.0:50051
CORE_DATAPLANE_NOOP=false
CORE_REQUIRE_TLS=true

WG_ENDPOINT_TEMPLATE={region}.vpn.example.net:51820
WG_SERVER_PUBLIC_KEY=replace_me
# Optional file-backed variant for startup-fetched Secret Manager material:
# WG_SERVER_PUBLIC_KEY_FILE=/var/run/secrets/core/server_public_key
WG_PRIVATE_KEY_PATH=/etc/wireguard/private.key
WG_INTERFACE=wg0
WG_INTERFACE_CIDR=10.90.0.1/24
WG_LISTEN_PORT=51820
WG_EGRESS_IFACE=eth0
WG_NAT_DRIVER=cli

CORE_TLS_CERT_PATH=/etc/core-tls/server.crt
CORE_TLS_KEY_PATH=/etc/core-tls/server.key
CORE_TLS_CLIENT_CA_CERT_PATH=/etc/core-tls/ca.pem
# In the startup rollout model, the paths above are populated from rollout_tls_*_secret_ref inputs rather than copied local files.

CORE_NODE_ID=00000000-0000-0000-0000-000000000001
# CORE_ENTRY_HEALTH_URL and CORE_ENTRY_NODE_UPSERT_URL are deprecated.
# entry now discovers node metadata from its node catalog and polls core over gRPC.
